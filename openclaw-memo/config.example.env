# OpenClaw Memo — Configuration Template
# Copy to config.env and fill in your values.

# ── Storage target ────────────────────────────────────────────────────────────
# Options: local | feishu | notion | apple
OPENCLAW_MEMO_STORAGE_TARGET=local

# ── Notes / digest files (relative to workspace root) ─────────────────────────
OPENCLAW_MEMO_NOTES_FILE=notes.md
OPENCLAW_MEMO_DIGEST_FILE=digest.md

# ── Search enrichment ─────────────────────────────────────────────────────────
# Set to enable auto-search for 待查 items.
OPENCLAW_MEMO_TAVILY_API_KEY=

# Whether to always enrich (1=yes). Can also pass --enrich flag.
OPENCLAW_MEMO_ENRICH=0

# ── Feishu (for feishu target OR Feishu IM notifications) ─────────────────────
# App ID and Secret from https://open.feishu.cn/app
OPENCLAW_MEMO_FEISHU_APP_ID=
OPENCLAW_MEMO_FEISHU_APP_SECRET=

# Feishu document token (extract from doc URL: /docx/<TOKEN>)
OPENCLAW_MEMO_FEISHU_DOC_TOKEN=

# Feishu chat_id to send digest notification (oc_xxx or ou_xxx)
OPENCLAW_MEMO_FEISHU_CHAT_ID=

# ── Notion (for notion target) ────────────────────────────────────────────────
OPENCLAW_MEMO_NOTION_API_KEY=
OPENCLAW_MEMO_NOTION_DATABASE_ID=

# ── Apple Notes (for apple target) ───────────────────────────────────────────
# Uses memo CLI — install with: brew install memo
OPENCLAW_MEMO_APPLE_NOTES_FOLDER=Memos
